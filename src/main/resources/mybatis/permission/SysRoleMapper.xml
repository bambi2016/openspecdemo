<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enterprise.permission.mapper.SysRoleMapper">

    <resultMap id="SysRoleMap" type="com.enterprise.permission.entity.SysRole">
        <id column="id" property="id"/>
        <result column="role_code" property="roleCode"/>
        <result column="role_name" property="roleName"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <insert id="insert" parameterType="com.enterprise.permission.entity.SysRole" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO sys_role (role_code, role_name, description, status, deleted, create_time, update_time)
        VALUES (#{roleCode}, #{roleName}, #{description}, #{status}, #{deleted}, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

    <select id="findById" resultMap="SysRoleMap">
        SELECT id, role_code, role_name, description, status, create_time, update_time, deleted
        FROM sys_role
        WHERE id = #{id}
          AND deleted = 0
          AND status = 1
    </select>

    <select id="countByRoleCode" resultType="int">
        SELECT COUNT(1)
        FROM sys_role
        WHERE role_code = #{roleCode}
          AND deleted = 0
    </select>

    <select id="countActiveByIds" resultType="int">
        SELECT COUNT(1)
        FROM sys_role
        WHERE deleted = 0
          AND status = 1
          AND id IN
          <foreach collection="ids" item="id" open="(" separator="," close=")">
              #{id}
          </foreach>
    </select>
</mapper>
