<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.enterprise.permission.mapper.SysPermissionMapper">

    <resultMap id="SysPermissionMap" type="com.enterprise.permission.entity.SysPermission">
        <id column="id" property="id"/>
        <result column="perm_code" property="permCode"/>
        <result column="perm_name" property="permName"/>
        <result column="description" property="description"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <select id="findById" resultMap="SysPermissionMap">
        SELECT id, perm_code, perm_name, description, status, create_time, update_time, deleted
        FROM sys_permission
        WHERE id = #{id}
          AND deleted = 0
          AND status = 1
    </select>

    <select id="countByPermCode" resultType="int">
        SELECT COUNT(1)
        FROM sys_permission
        WHERE perm_code = #{permCode}
          AND deleted = 0
    </select>

    <select id="countActiveByIds" resultType="int">
        SELECT COUNT(1)
        FROM sys_permission
        WHERE deleted = 0
          AND status = 1
          AND id IN
          <foreach collection="ids" item="id" open="(" separator="," close=")">
              #{id}
          </foreach>
    </select>

    <select id="findAllActive" resultMap="SysPermissionMap">
        SELECT id, perm_code, perm_name, description, status, create_time, update_time, deleted
        FROM sys_permission
        WHERE deleted = 0
          AND status = 1
        ORDER BY id
    </select>
</mapper>
